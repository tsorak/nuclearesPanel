{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nucleares-panel",
  "version": "0.31.1",
  "identifier": "com.karost.nucleares-panel",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nucleares Panel",
        "width": 800,
        "height": 600,
        "decorations": false,
        "visible": false,
        "transparent": true
      },
      {
        "label": "splash",
        "url": "src/splash.html",
        "width": 512,
        "height": 512,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true,
        "transparent": true,
        "javascriptDisabled":true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
